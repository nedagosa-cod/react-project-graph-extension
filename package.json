{
  "name": "antigravity-react-project-graph",
  "displayName": "React Project Graph",
  "description": "Visualiza el grafo de dependencias de tu proyecto React de manera interactiva y premium.",
  "version": "1.0.0",
  "publisher": "antigravity",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "antigravity-react-project-graph.showGraph",
        "title": "Grafo📍",
        "category": "React Project Graph"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "antigravity-react-project-graph.showGraph",
          "group": "navigation",
          "when": "resourceExtname == .js || resourceExtname == .jsx || resourceExtname == .ts || resourceExtname == .tsx"
        }
      ]
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.2.2",
      "onFail": "download"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.74.0"
  }
}